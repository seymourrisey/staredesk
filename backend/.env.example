# Application
APP_PORT=8080

# Database (Supabase PostgreSQL)
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgres://postgres.xxxxxxxxxxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require

# JWT
JWT_SECRET=your-secret-key-min-32-chars

# MQTT (HiveMQ Cloud)
MQTT_BROKER=your-cluster-id.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME=staredesk-backend
MQTT_PASSWORD=your-hivemq-password
MQTT_CLIENT_ID=staredesk-backend
MQTT_USER_ID=your-user-id
